rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // RÈGLES DE SOUVERAINETÉ ALIMENTAIRE - SAISON VIVRE
    
    // Parcelles et Zones de Culture
    match /drawn_parcels/{parcelId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Opportunités de Récolte et Analyses
    match /harvestOpportunities/{opId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Épingles de Scouting (Terrain)
    match /scouting_pins/{pinId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Règle par défaut pour les autres collections (Lecture seule)
    match /{document=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}