rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // RÈGLES SAISONPLUS AI - ÉDITION SOUVERAINETÉ SPATIALE (PRODUCTION)
    
    // Les opportunités de récolte sont lisibles par tous pour la transparence du marché
    match /harvestOpportunities/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Accès restreint aux rôles administratifs
    match /roles_admin/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }

    // Par défaut, toute écriture nécessite une authentification
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}